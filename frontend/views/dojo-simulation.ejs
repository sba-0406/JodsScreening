<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ScenarioSim | Interactive Simulation</title>
    <link rel="stylesheet" href="/css/style.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=JetBrains+Mono:wght@400;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=9">
    <style>
        /* Simulation-specific overrides */
        body {
            overflow: hidden;
            height: 100vh;
            background: var(--bg-main);
        }

        .simulation-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: #ffffff;
            border-bottom: 3px solid var(--primary-color);
            padding: 15px 40px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 1000;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
        }

        .mood-container {
            display: flex;
            align-items: center;
            gap: 24px;
            width: 100%;
        }

        .main-content {
            position: fixed;
            top: 140px;
            bottom: 240px;
            left: 0;
            right: 0;
            overflow-y: auto;
            padding: 40px 15%;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .interaction-zone {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            min-height: 180px;
            max-height: 240px;
            background: #ffffff;
            border-top: 1px solid var(--border);
            padding: 20px 15%;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 1000;
            overflow-y: auto;
            box-shadow: 0 -4px 15px rgba(0, 0, 0, 0.05);
        }

        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(30, 58, 138, 0.1);
            backdrop-filter: blur(12px);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .modal {
            background: #ffffff;
            padding: 40px;
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            border: 1px solid var(--border);
        }

        .typing-indicator {
            font-size: 0.8rem;
            color: var(--text-muted);
            font-style: italic;
            margin-bottom: 15px;
            display: none;
        }
    </style>
</head>

<body>
    <div class="navbar">
        <div class="container"
            style="display:flex; justify-content:space-between; align-items:center; width:100%; margin:0; max-width:none; padding:0;">
            <h2 style="margin:0;">ScenarioSim</h2>
            <div id="nav-links">
                <!-- Links built via main.js -->
            </div>
        </div>
    </div>

    <!-- HEADER -->
    <div class="simulation-header">
        <div class="header-top">
            <div class="sub-section-header" id="scenarioIndicator" style="margin: 0; flex: 1;">Scenario 1 / 3</div>
            <div class="timer" id="timer"
                style="font-family: 'JetBrains Mono'; font-weight: 700; color: var(--primary-color);">05:00</div>
            <button class="btn-sm btn-secondary" style="margin-left: 20px; color: var(--danger); border-color: #fee2e2;"
                id="skipBtn">Skip Stakeholder</button>
        </div>
        <div class="mood-container" id="metricsContainer">
            <!-- Metrics will be injected here -->
        </div>
    </div>

    <!-- CHAT FEED -->
    <div class="main-content" id="chatFeed">
        <!-- Messages loaded dynamicallly -->
        <div class="typing-indicator" id="typingIndicator">The stakeholder is thinking...</div>
    </div>

    <!-- INTERACTION ZONE -->
    <div class="interaction-zone" style="min-height: 200px;">
        <!-- 
        // DEPRECATED: Static MCQ Options are replaced by free-text evaluation
        <div class="mcq-options" id="mcqContainer">
        </div>

        <div class="divider">
            <span>OR TYPE CUSTOM RESPONSE</span>
        </div>
        -->

        <div
            style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">
            Your Response
        </div>
        <div class="text-input-group" style="flex: 1; align-items: stretch; gap: 15px;">
            <textarea id="customInput"
                placeholder="How would you handle this situation? Describe your actions and reasoning..."
                style="flex: 1; border: 1.5px solid var(--border); border-radius: 12px; padding: 15px; font-family: inherit; font-size: 1rem; resize: none; transition: border-color 0.2s;"
                autocomplete="off"></textarea>
            <button class="send-btn" id="sendBtn"
                style="height: auto; width: 60px; border-radius: 12px; background: var(--primary-color); color: white; border: none; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center;">➤</button>
        </div>
    </div>

    <!-- RESOLUTION OVERLAY -->
    <div class="overlay" id="resolutionOverlay">
        <div class="modal">
            <div style="font-size: 4rem; margin-bottom: 20px;" id="resolutionIcon">🎉</div>
            <h2 id="resolutionTitle" style="font-weight: 700; margin-bottom: 10px;">Scenario Resolved</h2>
            <p id="resolutionDesc" style="color: var(--text-muted); line-height: 1.6; margin-bottom: 30px;">You
                successfully navigated this challenge. Moving to next scenario...</p>
            <button class="btn" style="width: 100%; padding: 14px;" id="nextBtn">Continue Simulation ➤</button>
        </div>
    </div>

    <script src="/js/main.js"></script>
    <script>
        (function () {
            const sessionId = '<%= sessionId %>';
            const chatFeed = document.getElementById('chatFeed');
            const mcqContainer = document.getElementById('mcqContainer');
            const customInput = document.getElementById('customInput');
            const sendBtn = document.getElementById('sendBtn');
            const timerEl = document.getElementById('timer');
            const metricsContainer = document.getElementById('metricsContainer');

            let timeLeft = 300; // 5 minutes
            let timerInterval;
            let currentSession = null;

            document.addEventListener('DOMContentLoaded', init);

            async function init() {
                await loadSession();
                startTimer();
                setupInput();
            }

            async function loadSession() {
                try {
                    const res = await fetch(`/dojo/session/${sessionId}`);
                    const data = await res.json();
                    if (data.success) {
                        currentSession = data.data;

                        // If session is already completed, show the report immediately
                        if (currentSession.status === 'completed') {
                            finalizeSession();
                            return;
                        }

                        updateUI();
                        // Initial welcome message if feed is empty
                        if (currentSession.messages.length === 0) {
                            renderInitialMessage();
                        } else {
                            currentSession.messages.forEach(m => renderMessage(m));
                        }
                        // DEPRECATED: generateInitialMCQs();
                    }
                } catch (err) {
                    console.error("Load Session Failed:", err);
                    alert("Failed to load session details. Please check your connection.");
                }
            }

            function updateUI() {
                const step = currentSession.scenarioProgress.currentScenario;
                const total = currentSession.scenarioProgress.totalScenarios;
                document.getElementById('scenarioIndicator').textContent = `Scenario ${step} / ${total}: ${currentSession.persona.name}`;

                updateMetricsDisplay(currentSession.worldState);
            }

            function updateMetricsDisplay(worldState) {
                console.log("[DOJO] Updating Metrics:", worldState);
                if (!worldState) return;

                const polarity = currentSession.metricPolarity || {};
                let html = '';

                Object.entries(worldState).forEach(([metric, value]) => {
                    const actualValue = Math.max(0, Math.min(100, parseInt(value) || 0));
                    const metricPolarity = polarity[metric] || 'high'; // Default to 'high' if not specified

                    let color = '#10b981'; // Success (green)

                    // Determine color based on polarity
                    if (metricPolarity === 'high') {
                        // Higher is better (e.g., trust, morale)
                        if (actualValue < 40) color = '#f43f5e'; // Danger (red)
                        else if (actualValue < 70) color = '#f59e0b'; // Warning (orange)
                    } else if (metricPolarity === 'low') {
                        // Lower is better (e.g., risk, stress)
                        if (actualValue > 60) color = '#f43f5e'; // Danger (red) - high is bad!
                        else if (actualValue > 30) color = '#f59e0b'; // Warning (orange)
                        else color = '#10b981'; // Success (green) - low is good!
                    }

                    html += `
                        <div style="flex: 1; min-width: 120px;">
                            <div style="font-size: 0.7em; font-weight: 700; color: #94a3b8; text-transform: uppercase; margin-bottom: 5px;">
                                ${metric.replace(/([A-Z])/g, ' $1').trim()}
                            </div>
                            <div style="height: 12px; background: rgba(255,255,255,0.1); border-radius: 6px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05);">
                                <div style="height: 100%; width: ${actualValue}%; background: ${color}; transition: width 1s ease; box-shadow: 0 0 10px ${color}44;"></div>
                            </div>
                        </div>
                    `;
                });

                metricsContainer.innerHTML = html;
            }

            function startTimer() {
                timerInterval = setInterval(() => {
                    timeLeft--;
                    const mins = Math.floor(timeLeft / 60);
                    const secs = timeLeft % 60;
                    timerEl.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;

                    if (timeLeft <= 0) {
                        clearInterval(timerInterval);
                        onTimeout();
                    }
                }, 1000);
            }

            function setupInput() {
                sendBtn.onclick = () => handleResponse(customInput.value);
                customInput.onkeypress = (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleResponse(customInput.value); } };
                document.getElementById('skipBtn').onclick = skipScenario;
            }

            async function skipScenario() {
                if (!confirm("Are you sure you want to skip this stakeholder? It will be marked as unresolved in your report.")) return;
                const btn = document.getElementById('skipBtn');
                btn.disabled = true;
                btn.textContent = 'Skipping...';
                advanceScenario('skipped');
            }

            async function handleResponse(text, mcqChoice = null) {
                if (!text && !mcqChoice) return;

                // UI feedback
                const userText = mcqChoice ? mcqChoice.text : text;
                renderMessage({ sender: 'user', text: userText });
                customInput.value = '';
                // mcqContainer.innerHTML = ''; // DEPRECATED
                document.getElementById('typingIndicator').style.display = 'block';
                scrollToBottom();

                try {
                    const res = await fetch('/dojo/respond', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ sessionId, message: text, mcqChoice }),
                        credentials: 'include'
                    });
                    const data = await res.json();

                    document.getElementById('typingIndicator').style.display = 'none';

                    if (data.success) {
                        renderMessage({ sender: 'ai', text: data.data.message });
                        updateMetricsDisplay(data.data.worldState);
                        // renderMCQs(data.data.mcqOptions); // DEPRECATED

                        if (data.data.isResolved) {
                            showResolution('success', data.data.isLastScenario);
                        }
                    }
                } catch (err) { console.error(err); }
            }

            /*
            // DEPRECATED: renderMCQs and generateInitialMCQs
            function renderMCQs(options) {
                mcqContainer.innerHTML = '';
                options.forEach(opt => {
                    const btn = document.createElement('button');
                    btn.className = 'mcq-btn';

                    let impactHtml = '';
                    if (opt.satisfies || opt.violates) {
                        impactHtml = `
                            <div style="display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap;">
                                ${opt.satisfies ? `<span style="font-size: 0.7em; background: rgba(16, 185, 129, 0.1); color: #34d399; padding: 2px 8px; border-radius: 4px; border: 1px solid rgba(16, 185, 129, 0.2);">✓ Satisfies: ${opt.satisfies}</span>` : ''}
                                ${opt.violates ? `<span style="font-size: 0.7em; background: rgba(244, 63, 94, 0.1); color: #fb7185; padding: 2px 8px; border-radius: 4px; border: 1px solid rgba(244, 63, 94, 0.2);">⚠ Violates: ${opt.violates}</span>` : ''}
                            </div>
                        `;
                    }

                    btn.innerHTML = `
                        <div style="width: 100%;">
                            <div style="display: flex; align-items: flex-start; gap: 12px;">
                                <span style="font-size: 1.2em;">${getApproachEmoji(opt.approach)}</span>
                                <div style="flex: 1;">
                                    <div style="font-size: 0.95em;">${opt.text}</div>
                                    ${impactHtml}
                                </div>
                            </div>
                        </div>
                    `;
                    btn.onclick = () => handleResponse(null, opt);
                    mcqContainer.appendChild(btn);
                });
            }

            function getApproachEmoji(approach) {
                switch (approach) {
                    case 'Relationship': return '👥';
                    case 'Results': return '🎯';
                    case 'Boundary': return '🛡️';
                    default: return '💡';
                }
            }

            async function generateInitialMCQs() {
                // Fetch first set if empty
                if (mcqContainer.children.length === 0) {
                    const res = await fetch('/dojo/respond', { // This is a bit of a hack to reuse logic
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ sessionId, message: '' }), // Empty triggers MCQ generation
                        credentials: 'include'
                    });
                    const d = await res.json();
                    if (d.success) renderMCQs(d.data.mcqOptions);
                }
            }
            */

            function renderMessage(msg) {
                const div = document.createElement('div');
                div.className = `chat-bubble ${msg.sender}`;
                div.textContent = msg.text;
                chatFeed.insertBefore(div, document.getElementById('typingIndicator'));
                scrollToBottom();
            }

            function renderInitialMessage() {
                const txt = `[MISSION START] You are now in conversation with ${currentSession.persona.name}. 
                Situation: ${currentSession.persona.briefing.situation}.
                Can you resolve the issue?`;
                renderMessage({ sender: 'ai', text: txt });
            }

            function scrollToBottom() {
                chatFeed.scrollTop = chatFeed.scrollHeight;
            }

            function showResolution(type, isLast = false) {
                clearInterval(timerInterval);
                const overlay = document.getElementById('resolutionOverlay');
                const title = document.getElementById('resolutionTitle');
                const icon = document.getElementById('resolutionIcon');
                const desc = document.getElementById('resolutionDesc');
                const nextBtn = document.getElementById('nextBtn');

                if (type === 'success') {
                    title.textContent = "Scenario Resolved!";
                    icon.textContent = "✅";
                    desc.textContent = "Excellent work. You successfully appeased the stakeholder.";
                } else {
                    title.textContent = "Scenario Failed";
                    icon.textContent = "⏱️";
                    desc.textContent = "Time expired before resolution was reached.";
                }

                if (isLast || (currentSession && currentSession.scenarioProgress.currentScenario >= 3)) {
                    nextBtn.textContent = "Finish & See Career Results";
                } else {
                    nextBtn.textContent = "Next Stakeholder";
                }

                overlay.style.display = 'flex';
                nextBtn.onclick = () => advanceScenario();
            }

            async function advanceScenario(reason = null) {
                try {
                    const res = await fetch('/dojo/next', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ sessionId, reason: reason || (timeLeft > 0 ? 'success' : 'timeout') }),
                        credentials: 'include'
                    });
                    const data = await res.json();
                    if (data.success) {
                        if (data.data.isComplete) {
                            finalizeSession();
                        } else {
                            window.location.reload();
                        }
                    } else {
                        alert("Movement failed: " + (data.error || "Unknown error"));
                        document.getElementById('skipBtn').disabled = false;
                        document.getElementById('skipBtn').textContent = 'Skip Stakeholder';
                    }
                } catch (err) {
                    console.error("Advance Error:", err);
                    alert("System error advancing simulation. Check connection.");
                    document.getElementById('skipBtn').disabled = false;
                }
            }

            async function finalizeSession() {
                try {
                    const res = await fetch('/dojo/finalize', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ sessionId }),
                        credentials: 'include'
                    });
                    const data = await res.json();
                    if (data.success) {
                        showFinalReport(data.data);
                    } else {
                        alert("Error generating final report: " + data.error);
                    }
                } catch (err) {
                    console.error("Finalization error:", err);
                    alert("System error finishing simulation. Please try again or check server logs.");
                }
            }

            function showFinalReport(report) {
                const overlay = document.getElementById('resolutionOverlay');
                overlay.style.display = 'flex';

                let skillsHtml = '';
                if (report.skillScores) {
                    Object.entries(report.skillScores).forEach(([skill, score]) => {
                        const scorePercent = Math.min(100, (score / 10) * 100); // Assuming 10 is max per skill
                        skillsHtml += `
                            <div style="margin-bottom: 20px;">
                                <div style="display: flex; justify-content: space-between; font-size: 0.9rem; margin-bottom: 8px; color: var(--text-main); font-weight: 600;">
                                    <span>${skill}</span>
                                    <span style="color: var(--primary-color);">${score} / 10</span>
                                </div>
                                <div style="height: 8px; background: #f1f5f9; border-radius: 4px; overflow: hidden; border: 1px solid var(--border);">
                                    <div style="height: 100%; width: ${scorePercent}%; background: var(--primary-color); transition: width 1s ease;"></div>
                                </div>
                            </div>
                        `;
                    });
                }

                overlay.innerHTML = `
                    <div class="modal" style="max-width: 600px; width: 95%;">
                        <div style="font-size: 0.75rem; color: var(--primary-color); text-transform: uppercase; letter-spacing: 2px; font-weight: 800; margin-bottom: 10px;">Simulation Complete</div>
                        <h1 style="font-size: 5rem; margin: 0 0 20px; color: var(--primary-color); font-weight: 800;">${report.overallGrade}</h1>
                        
                        <div style="background: #f8fafc; padding: 25px; border-radius: 16px; margin-bottom: 25px; text-align: left; border: 1px solid var(--border);">
                            <h4 style="color: var(--text-main); margin-bottom: 20px; font-size: 1.1rem; font-weight: 700;">Behavioral Competency Profile</h4>
                            ${skillsHtml}
                        </div>

                        <div style="background: #eff6ff; padding: 20px; border-radius: 16px; margin-bottom: 30px; text-align: left; border: 1px solid #dbeafe;">
                            <h4 style="color: var(--primary-color); margin-bottom: 8px; font-size: 0.8rem; text-transform: uppercase; font-weight: 800;">AI Performance Summary</h4>
                            <p style="color: var(--text-main); line-height: 1.6; font-size: 0.95rem;">${report.recommendation}</p>
                        </div>
                        
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            <button onclick="window.location.href='/api/applications/my-dashboard'" class="btn" style="padding: 16px; width: 100%; font-size: 1.1rem; font-weight: 700;">
                                Return to Dashboard
                            </button>
                            <button onclick="window.location.reload()" style="background: transparent; border: 1px solid var(--border); color: var(--text-muted); padding: 12px; border-radius: 12px; cursor: pointer; font-family: inherit; font-weight: 600;">
                                Restart Simulation
                            </button>
                        </div>
                    </div>
                `;
            }

            function onTimeout() { showResolution('timeout'); }

        })();
    </script>
</body>

</html>