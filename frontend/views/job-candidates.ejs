<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | ScenarioSim
    </title>
    <link rel="stylesheet" href="/css/style.css?v=9">
    <style>
        /* ── Candidates Table ───────────────── */
        .candidates-table {
            width: 100%;
            border-collapse: collapse;
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }

        .candidates-table th,
        .candidates-table td {
            padding: 1rem 1.25rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        .candidates-table th {
            background: #f8fafc;
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .candidates-table tr:last-child td {
            border-bottom: none;
        }

        .candidates-table tbody tr:hover {
            background: #f8faff;
        }

        .candidate-name {
            font-weight: 600;
            color: var(--text-main);
        }

        .candidate-email {
            font-size: 0.825rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* Score badges */
        .score-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-weight: 700;
            font-size: 0.825rem;
        }

        .score-high {
            background: #ecfdf5;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        .score-medium {
            background: #fffbeb;
            color: #d97706;
            border: 1px solid #fde68a;
        }

        .score-low {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        /* Application status badges */
        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .status-applied {
            background: #eff6ff;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

        .status-reviewing {
            background: #f5f3ff;
            color: #7c3aed;
            border: 1px solid #ddd6fe;
        }

        .status-shortlisted {
            background: #ecfdf5;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        .status-interview_scheduled {
            background: #f0fdf4;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .status-rejected {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .status-hired {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #6ee7b7;
        }

        /* Assessment status pill */
        .assessment-pill {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 600;
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
        }

        .assessment-pill.completed {
            background: #ecfdf5;
            color: #16a34a;
            border-color: #bbf7d0;
        }

        /* Fit label */
        .fit-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-muted);
        }

        .fit-label.strong {
            color: #16a34a;
        }

        .fit-label.moderate {
            color: #d97706;
        }

        .fit-label.weak {
            color: #dc2626;
        }

        /* Page header */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.5rem;
        }

        .page-header h1 {
            font-size: 1.5rem;
            color: var(--text-main);
            margin: 0 0 4px;
        }

        .page-header p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin: 0;
        }
    </style>
</head>

<body class="has-sidebar">
    <%- include('partials/_navbar') %>

        <div class="main-wrapper">
            <div class="container">

                <!-- Page Header -->
                <div class="page-header">
                    <div>
                        <h1>Candidates for <em>
                                <%= job.title %>
                            </em></h1>
                        <p>
                            <%= candidates.length %> total application<%= candidates.length !==1 ? 's' : '' %>
                        </p>
                    </div>
                    <a href="/api/jobs/dashboard" class="btn btn-secondary">← Back to Dashboard</a>
                </div>

                <!-- Pool Insights Bar -->
                <div id="pool-insights-bar" class="card"
                    style="padding: 16px 24px; margin-bottom: 20px; display: none;">
                    <p
                        style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px;">
                        📊 Pool Intelligence — Candidates Who Completed Assessment</p>
                    <div style="display: flex; gap: 32px; flex-wrap: wrap;">
                        <div><span style="font-size: 1.4rem; font-weight: 800; color: var(--primary-color);"
                                id="pi-avg-score">—</span><br><small style="color:var(--text-muted)">Avg. Weighted
                                Score</small></div>
                        <div><span style="font-size: 1.4rem; font-weight: 800; color: var(--secondary-color);"
                                id="pi-avg-tech">—</span><br><small style="color:var(--text-muted)">Avg. Technical
                                Score</small></div>
                        <div><span style="font-size: 1.4rem; font-weight: 800; color: var(--success);"
                                id="pi-avg-soft">—</span><br><small style="color:var(--text-muted)">Avg. Soft Skill
                                Score</small></div>
                        <div><span style="font-size: 1.4rem; font-weight: 800; color: var(--warning);"
                                id="pi-avg-exp">—</span><br><small style="color:var(--text-muted)">Avg. Experience
                                (yrs)</small></div>
                        <div><span style="font-size: 1.4rem; font-weight: 800; color: var(--info);"
                                id="pi-high-pot">—</span><br><small style="color:var(--text-muted)">High
                                Potential</small></div>
                    </div>
                </div>

                <!-- Candidates Table -->
                <div class="card" style="padding: 0; overflow: hidden;">
                    <table class="candidates-table">
                        <thead>
                            <tr>
                                <th><a href="?sort=name" style="color: inherit; text-decoration: none;">Candidate ↕</a>
                                </th>
                                <th>Status</th>
                                <th>Assessment</th>
                                <th><a href="?sort=score" style="color: inherit; text-decoration: none;">Score ↕</a>
                                </th>
                                <th>Fit</th>
                                <th title="Weighted by Tech (40%), Soft Skills (30%), Experience (30%)">Match Rank 🎯
                                </th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (candidates.length===0) { %>
                                <tr>
                                    <td colspan="7" class="empty-state" style="color: var(--text-muted);">
                                        No candidates found for this position yet.
                                    </td>
                                </tr>
                                <% } else { %>
                                    <% candidates.forEach(candidate=> { %>
                                        <% const score=candidate.assessmentResults?.weightedScore; %>
                                            <% const fit=candidate.assessmentResults?.overallFit || '' ; %>
                                                <tr>
                                                    <td>
                                                        <div class="candidate-name">
                                                            <%= candidate.candidateName %>
                                                        </div>
                                                        <div class="candidate-email">
                                                            <%= candidate.candidateEmail %>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <span class="status-badge status-<%= candidate.status %>">
                                                            <%= candidate.status.replace(/_/g, ' ' ) %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span
                                                            class="assessment-pill <%= candidate.assessmentStatus === 'completed' ? 'completed' : '' %>">
                                                            <%= candidate.assessmentStatus.replace(/_/g, ' '
                                                                ).toUpperCase() %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <% if (score !==undefined && score !==null) { %>
                                                            <span
                                                                class="score-badge <%= score >= 70 ? 'score-high' : score >= 50 ? 'score-medium' : 'score-low' %>">
                                                                <%= score %>%
                                                            </span>
                                                            <% } else { %>
                                                                <span style="color: var(--text-muted);">—</span>
                                                                <% } %>
                                                    </td>
                                                    <td>
                                                        <% if (fit) { %>
                                                            <span
                                                                class="fit-label <%= fit.toLowerCase().includes('strong') ? 'strong' : fit.toLowerCase().includes('moderate') ? 'moderate' : 'weak' %>">
                                                                <%= fit %>
                                                            </span>
                                                            <% } else { %>
                                                                <span style="color: var(--text-muted);">—</span>
                                                                <% } %>
                                                    </td>
                                                    <td>
                                                        <% if (candidate.matchScore> 0) { %>
                                                            <div style="display: flex; align-items: center; gap: 8px;">
                                                                <div
                                                                    style="flex:1; background: var(--border); border-radius: 4px; height: 6px; overflow:hidden;">
                                                                    <div
                                                                        style="width:<%= candidate.matchScore %>%; height:100%; background: <%= candidate.matchScore >= 70 ? 'var(--success)' : candidate.matchScore >= 50 ? 'var(--warning)' : 'var(--danger)' %>; border-radius: 4px;">
                                                                    </div>
                                                                </div>
                                                                <span
                                                                    style="font-size: 0.8rem; font-weight: 700; color: var(--text-main); min-width: 32px;">
                                                                    <%= candidate.matchScore %>%
                                                                </span>
                                                            </div>
                                                            <% } else { %>
                                                                <span
                                                                    style="color: var(--text-muted); font-size: 0.8rem;">Pending</span>
                                                                <% } %>
                                                    </td>
                                                    <td>
                                                        <a href="/api/applications/application/<%= candidate._id %>/view"
                                                            class="btn btn-sm">View Profile</a>
                                                        <% if (candidate.status !=='rejected' && candidate.status
                                                            !=='hired' && candidate.assessmentStatus !=='completed' &&
                                                            job.requireAssessment) { %>
                                                            <button class="btn btn-sm btn-secondary"
                                                                onclick="openInviteModal('<%= candidate.candidate %>', '<%= candidate.candidateName %>')">
                                                                Invite to Assessment
                                                            </button>
                                                            <% } %>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } %>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

        <!-- Assessment Invitation Modal -->
        <div id="message-modal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Send Assessment Invite: <span id="modal-candidate-name"></span></h2>
                    <button class="close-btn" onclick="closeInviteModal()">&times;</button>
                </div>
                <div class="modal-body">
                    <p style="margin-bottom: 15px; font-size: 0.9rem; color: var(--text-muted);">
                        This will send a notification to the candidate with instructions to start their scenario
                        assessment.
                    </p>
                    <input type="hidden" id="template-select" value="assessment_invite">
                </div>
                <div class="form-group">
                    <label>Message Preview</label>
                    <div id="message-preview" class="template-preview">
                        Select a template to see a preview...
                    </div>
                </div>
                <div class="modal-actions"
                    style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;">
                    <button class="btn btn-secondary" onclick="closeInviteModal()">Cancel</button>
                    <button class="btn btn-block" id="send-btn" onclick="sendMessage()" disabled>Send
                        Invitation</button>
                </div>
            </div>
        </div>

        <script>
            let currentCandidateId = null;
            let currentCandidateName = null;
            let templates = [];
            const jobTitle = "<%= job.title %>";
            const jobId = "<%= job._id %>";

            // Auto-fetch pool insights on page load
            (async () => {
                try {
                    const res = await fetch(`/api/jobs/${jobId}/pool-insights`);
                    const data = await res.json();
                    if (data.success && data.data.poolStats.totalCandidates > 0) {
                        const s = data.data.poolStats;
                        document.getElementById('pi-avg-score').textContent = `${s.avgWeightedScore || '—'}%`;
                        document.getElementById('pi-avg-tech').textContent = `${s.avgTechScore || '—'}%`;
                        document.getElementById('pi-avg-soft').textContent = `${s.avgSoftScore || '—'}%`;
                        document.getElementById('pi-avg-exp').textContent = `${s.avgExperience || '—'} yrs`;
                        document.getElementById('pi-high-pot').textContent = `${s.highPotentialCount || 0} / ${s.totalCandidates}`;
                        document.getElementById('pool-insights-bar').style.display = 'block';
                    }
                } catch (e) { console.warn('Pool insights unavailable'); }
            })();

            async function openInviteModal(candidateId, candidateName) {
                currentCandidateId = candidateId;
                currentCandidateName = candidateName;
                document.getElementById('modal-candidate-name').textContent = candidateName;
                document.getElementById('message-modal').classList.add('active');

                // Load template for preview
                if (templates.length === 0) {
                    try {
                        const res = await fetch('/api/notifications/templates');
                        const data = await res.json();
                        if (data.success) {
                            templates = data.data;
                        }
                    } catch (err) { console.error(err); }
                }

                const template = templates.find(t => t.name === 'assessment_invite');
                if (template) {
                    let body = template.body;
                    body = body.replace(/{{candidateName}}/g, currentCandidateName);
                    body = body.replace(/{{jobTitle}}/g, jobTitle);
                    document.getElementById('message-preview').textContent = body;
                    document.getElementById('send-btn').disabled = false;
                }
            }

            function closeInviteModal() {
                document.getElementById('message-modal').classList.remove('active');
            }

            async function sendMessage() {
                const sendBtn = document.getElementById('send-btn');
                try {
                    sendBtn.disabled = true;
                    sendBtn.textContent = 'Sending...';

                    const response = await fetch('/api/notifications/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            recipientId: currentCandidateId,
                            templateName: 'assessment_invite',
                            data: {
                                candidateName: currentCandidateName,
                                jobTitle: jobTitle
                            }
                        })
                    });

                    const data = await response.json();
                    if (data.success) {
                        alert('Notification sent successfully!');
                        closeMessageModal();
                    } else {
                        alert('Error: ' + data.error);
                    }
                } catch (err) {
                    console.error('Failed to send notification:', err);
                    alert('Failed to send notification.');
                } finally {
                    sendBtn.disabled = false;
                    sendBtn.textContent = 'Send Message';
                }
            }
        </script>
</body>

</html>