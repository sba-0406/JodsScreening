            async function publishJob() {
                if (!confirm('Publish this job? It will be visible to candidates.')) return;

                try {
                    const response = await fetch(`/api/jobs/${jobId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status: 'active' })
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('Job published successfully!');
                        location.reload();
                    } else {
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    alert('Error publishing job');
                }
            }

            async function closeJob() {
                if (!confirm('Close this job? No new applications will be accepted.')) return;

                try {
                    const response = await fetch(`/api/jobs/${jobId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status: 'closed' })
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('Job closed successfully!');
                        location.reload();
                    } else {
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    alert('Error closing job');
                }
            }

            async function generateAssessment() {
                if (!confirm('Generate assessment for this job?')) return;

                try {
                    const response = await fetch(`/api/jobs/${jobId}/generate-assessment`, {
                        method: 'POST'
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('Assessment generated successfully!');
                        location.reload();
                    } else {
