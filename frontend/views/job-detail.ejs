            async function deleteJob() {
                if (!confirm('⚠️ Are you sure you want to permanently delete this job and its assessment? This cannot be undone.')) return;

                try {
                    const response = await fetch(`/api/jobs/${jobId}`, { method: 'DELETE' });
                    const result = await response.json();
                    if (result.success) {
                        alert('Job deleted successfully.');
                        window.location.href = '/api/jobs/dashboard';
                    } else {
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    alert('Error deleting job');
                }
            }

            // New Manual Entry Handlers
            function toggleManualQuestionForm() {
                const form = document.getElementById('manual-question-form');
                form.style.display = form.style.display === 'none' ? 'block' : 'none';
            }

            function toggleManualScenarioForm() {
                const form = document.getElementById('manual-scenario-form');
                form.style.display = form.style.display === 'none' ? 'block' : 'none';
            }

            async function refineHRContent(fieldId, type) {
                const textarea = document.getElementById(fieldId);
                const text = textarea.value.trim();
                if (!text) return alert('Please enter some text first');

                const btn = event.currentTarget;
                const originalText = btn.innerHTML;
                btn.innerHTML = '...';
                btn.disabled = true;

                try {
                    const response = await fetch('/api/jobs/refine-content', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ text, type })
                    });
                    const result = await response.json();
                    if (result.success) {
                        textarea.value = result.data;
                    }
                } catch (err) {
                    console.error('Refinement failed', err);
                } finally {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            }

            async function saveManualQuestion() {
                const data = {
                    question: document.getElementById('mq-text').value,
                    skill: document.getElementById('mq-skill').value,
                    difficulty: document.getElementById('mq-diff').value,
                    correctAnswer: parseInt(document.getElementById('mq-correct').value),
                    options: [
                        document.getElementById('mq-opt-0').value,
                        document.getElementById('mq-opt-1').value,
                        document.getElementById('mq-opt-2').value,
                        document.getElementById('mq-opt-3').value
                    ]
                };

                if (!data.question || data.options.some(o => !o)) return alert('Please fill all fields');

                try {
                    const response = await fetch(`/api/jobs/${jobId}/manual-question`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    }
                } catch (err) {
                    alert('Error saving question');
                }
            }

            async function saveManualScenario() {
                const data = {
                    softSkill: document.getElementById('ms-skill').value,
                    theme: document.getElementById('ms-theme').value,
                    stakeholder: document.getElementById('ms-stakeholder').value,
                    prompt: document.getElementById('ms-prompt').value
                };

                if (!data.theme || !data.stakeholder || !data.prompt) return alert('Please fill all fields');

                try {
                    const response = await fetch(`/api/jobs/${jobId}/manual-scenario`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    }
                } catch (err) {
                    alert('Error saving scenario');
                }
            }
        </script>
